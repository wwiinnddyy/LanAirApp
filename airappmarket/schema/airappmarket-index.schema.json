{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/wwiinnddyy/LanAirApp/main/airappmarket/schema/airappmarket-index.schema.json",
  "title": "AirAppMarket Index v3 (self-contained flat)",
  "description": "Official LanMountainDesktop market index. Every plugin entry is self-contained: all display and acquisition metadata lives inline, so the host never calls back to GitHub to enrich entries.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "sourceId",
    "sourceName",
    "generatedAt",
    "plugins"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "3.0.0"
    },
    "sourceId": {
      "type": "string",
      "minLength": 1
    },
    "sourceName": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "contracts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/contract"
      }
    },
    "plugins": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/plugin"
      }
    }
  },
  "$defs": {
    "url": {
      "type": "string",
      "format": "uri"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "releaseTag": {
      "type": "string",
      "pattern": "^v\\d+\\.\\d+\\.\\d+$"
    },
    "hex64": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{64}$"
    },
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "assemblyName",
        "downloadUrl",
        "sha256",
        "packageSizeBytes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "$ref": "#/$defs/version"
        },
        "assemblyName": {
          "type": "string",
          "minLength": 1
        },
        "downloadUrl": {
          "$ref": "#/$defs/url"
        },
        "sha256": {
          "$ref": "#/$defs/hex64"
        },
        "packageSizeBytes": {
          "type": "integer",
          "exclusiveMinimum": 0
        }
      }
    },
    "dependency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "assemblyName"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "$ref": "#/$defs/version"
        },
        "assemblyName": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "packageSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "url"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "releaseAsset",
            "rawFallback",
            "workspaceLocal"
          ]
        },
        "url": {
          "type": "string"
        }
      }
    },
    "plugin": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pluginId",
        "name",
        "description",
        "author",
        "version",
        "apiVersion",
        "repositoryUrl",
        "packageSources"
      ],
      "properties": {
        "pluginId": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "author": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "$ref": "#/$defs/version"
        },
        "apiVersion": {
          "$ref": "#/$defs/version"
        },
        "minHostVersion": {
          "$ref": "#/$defs/version"
        },
        "entranceAssembly": {
          "type": "string"
        },
        "iconUrl": {
          "type": "string"
        },
        "readmeUrl": {
          "type": "string"
        },
        "projectUrl": {
          "type": "string"
        },
        "homepageUrl": {
          "type": "string"
        },
        "repositoryUrl": {
          "$ref": "#/$defs/url"
        },
        "releaseTag": {
          "$ref": "#/$defs/releaseTag"
        },
        "releaseAssetName": {
          "type": "string"
        },
        "sha256": {
          "$ref": "#/$defs/hex64"
        },
        "md5": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{32}$"
        },
        "packageSizeBytes": {
          "type": "integer",
          "minimum": 0
        },
        "publishedAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "releaseNotes": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sharedContracts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dependency"
          }
        },
        "packageSources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/packageSource"
          }
        },
        "desktopComponents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "settingsSections": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "exports": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "messageTypes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
