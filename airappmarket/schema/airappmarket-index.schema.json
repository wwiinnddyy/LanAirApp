{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/wwiinnddyy/LanAirApp/main/airappmarket/schema/airappmarket-index.schema.json",
  "title": "AirAppMarket Index v3",
  "description": "Official LanMountainDesktop market link index. Version and dependency truth stay in the plugin repository itself.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "sourceId",
    "sourceName",
    "generatedAt",
    "plugins"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "3.0.0"
    },
    "sourceId": {
      "type": "string",
      "minLength": 1
    },
    "sourceName": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "plugins": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/plugin"
      }
    }
  },
  "$defs": {
    "url": {
      "type": "string",
      "format": "uri"
    },
    "packageSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "url"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "releaseAsset",
            "rawFallback",
            "workspaceLocal"
          ]
        },
        "url": {
          "$ref": "#/$defs/url"
        }
      }
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repositoryUrl"
      ],
      "properties": {
        "iconUrl": {
          "$ref": "#/$defs/url"
        },
        "projectUrl": {
          "$ref": "#/$defs/url"
        },
        "readmeUrl": {
          "$ref": "#/$defs/url"
        },
        "homepageUrl": {
          "$ref": "#/$defs/url"
        },
        "repositoryUrl": {
          "$ref": "#/$defs/url"
        }
      }
    },
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packageSources"
      ],
      "properties": {
        "packageSources": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "prefixItems": [
            {
              "allOf": [
                {
                  "$ref": "#/$defs/packageSource"
                },
                {
                  "properties": {
                    "kind": {
                      "const": "releaseAsset"
                    }
                  }
                }
              ]
            },
            {
              "allOf": [
                {
                  "$ref": "#/$defs/packageSource"
                },
                {
                  "properties": {
                    "kind": {
                      "const": "rawFallback"
                    }
                  }
                }
              ]
            },
            {
              "allOf": [
                {
                  "$ref": "#/$defs/packageSource"
                },
                {
                  "properties": {
                    "kind": {
                      "const": "workspaceLocal"
                    }
                  }
                }
              ]
            }
          ],
          "items": false
        }
      }
    },
    "plugin": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pluginId",
        "repository",
        "publication"
      ],
      "properties": {
        "pluginId": {
          "type": "string",
          "minLength": 1
        },
        "repository": {
          "$ref": "#/$defs/repository"
        },
        "publication": {
          "$ref": "#/$defs/publication"
        }
      }
    }
  }
}
